{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flask Backend",
      "type": "python",
      "request": "launch",
      "module": "flask",
      "env": {
        "FLASK_APP": "app.py",
        "FLASK_DEBUG": "1"
      },
      "args": ["run", "--port", "5000"],
      "cwd": "${workspaceFolder}/backend",
      "jinja": true
    }
  ]
}
